# Postgres connection from Neon, Vercel Postgres, or Supabase.
# Use the pooled URL for runtime. If your provider gives a separate direct URL,
# put it in DIRECT_DATABASE_URL — Prisma uses it for migrations.
DATABASE_URL=postgres://...
DIRECT_DATABASE_URL=postgres://...

# Required for Auth.js sessions. Generate with: openssl rand -base64 32
AUTH_SECRET=

# Email magic-link sign-in (Resend — https://resend.com/api-keys)
RESEND_API_KEY=
# Sender — use "onboarding@resend.dev" for testing without a verified domain.
EMAIL_FROM=onboarding@resend.dev
# Optional allowlist (comma-separated). If empty, the first email to sign in
# becomes admin and locks the door behind it.
ALLOWED_EMAILS=

# SerpApi key (https://serpapi.com/manage-api-key) — used for competitive SERP
# analysis before generating each article. Free tier: 100 searches/month.
SERPAPI_KEY=

# Unsplash Access Key (https://unsplash.com/developers) — used to attach a
# hero image to every article. Free demo tier: 50 requests/hour, no card.
# Sign up, create a new application, copy the Access Key. Leave blank to
# skip image embedding entirely.
UNSPLASH_ACCESS_KEY=

# Encryption key for storing WordPress Application Passwords at rest.
# Must be 32 bytes base64-encoded. Generate with: openssl rand -base64 32
ENCRYPTION_KEY=

# Anthropic API (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Optional: token used by Vercel Cron to authenticate scheduled runs.
# Generate any random string. Vercel Cron sends it as Authorization: Bearer <token>.
CRON_SECRET=

# Optional: X (Twitter) credentials for auto-posting after publish.
# X_API_KEY=
# X_API_SECRET=
# X_ACCESS_TOKEN=
# X_ACCESS_SECRET=

# Optional: Reddit credentials.
# REDDIT_CLIENT_ID=
# REDDIT_CLIENT_SECRET=
# REDDIT_USERNAME=
# REDDIT_PASSWORD=
# REDDIT_USER_AGENT=auto-seo
