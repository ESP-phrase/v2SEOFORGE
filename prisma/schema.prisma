generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Neon Postgres for both local dev and Vercel production — same DB.
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// Auth.js v5 standard models (cuid string IDs)
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  lastLogin     DateTime?

  accounts Account[]
  sessions Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Cached SerpApi responses — keyed by keyword to avoid burning the free tier.
// Refreshed when older than the TTL configured in lib/serp.ts.
model SerpCache {
  keyword   String   @id
  json      String
  fetchedAt DateTime @default(now())
}

// Backlink outreach prospects — resource pages, niche blogs, etc. that should
// link to one of the site's articles. Each row is a single target. The whole
// pipeline (find → score → draft email → manual send → track) lives off this.
model OutreachProspect {
  id              Int       @id @default(autoincrement())
  siteId          Int
  site            Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  url             String
  domain          String
  pageTitle       String
  snippet         String    @default("")
  searchSeed      String    @default("") // the query that surfaced this prospect
  relevanceScore  Int       @default(50)
  scoreReason     String    @default("")
  status          String    @default("new") // new | drafted | sent | replied | won | dead
  contactEmail    String?
  draftSubject    String    @default("")
  draftBody       String    @default("")
  notes           String    @default("")
  targetArticleId Int?
  targetArticle   Article?  @relation(fields: [targetArticleId], references: [id], onDelete: SetNull)
  sentAt          DateTime?
  repliedAt       DateTime?
  linkedAt        DateTime?
  createdAt       DateTime  @default(now())

  @@unique([siteId, url])
  @@index([siteId, status])
}

model Site {
  id              Int      @id @default(autoincrement())
  slug            String   @unique
  name            String
  wpUrl           String
  wpUsername      String
  // Encrypted with ENCRYPTION_KEY. Never stored in plaintext.
  wpAppPasswordEnc String
  niche           String   @default("")
  audience        String   @default("")
  expertVoice     String   @default("")
  authorBioHtml   String   @default("")
  ctaHtml         String   @default("")
  maxPerDay       Int      @default(2)
  minWordCount    Int      @default(1000)
  publishStatus   String   @default("draft")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())

  keywords Keyword[]
  articles Article[]
  runs     Run[]
  outreachProspects OutreachProspect[]
  pageViews         PageView[]
}

model Keyword {
  id          Int       @id @default(autoincrement())
  siteId      Int
  site        Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  keyword     String
  intent      String    @default("informational")
  status      String    @default("queued")
  createdAt   DateTime  @default(now())
  processedAt DateTime?

  articles Article[]
  runs     Run[]

  @@unique([siteId, keyword])
  @@index([siteId, status])
}

model Article {
  id              Int       @id @default(autoincrement())
  siteId          Int
  site            Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  keywordId       Int
  keyword         Keyword   @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  title           String
  slug            String
  metaDescription String    @default("")
  html            String
  wordCount       Int       @default(0)
  wpPostId        Int?
  wpUrl           String?
  status          String    @default("draft")
  // JSON-encoded arrays
  categoriesJson  String    @default("[]")
  tagsJson        String    @default("[]")
  inputTokens     Int       @default(0)
  outputTokens    Int       @default(0)
  costUsd         Float     @default(0)
  serpJson        String?   // snapshot of SERP analysis used at generation time
  createdAt       DateTime  @default(now())
  publishedAt     DateTime?

  socialPosts SocialPost[]
  runs        Run[]
  outreachProspects OutreachProspect[]
  pageViews   PageView[]

  @@index([siteId, publishedAt])
}

model SocialPost {
  id         Int      @id @default(autoincrement())
  articleId  Int
  article    Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  platform   String
  externalId String?
  postedAt   DateTime @default(now())
}

// Self-hosted pageview tracking. Articles published to WordPress include a
// tiny beacon snippet that POSTs to /api/track on every load. Stored raw so we
// can aggregate by article, day, country, or referrer in the Analytics tab.
model PageView {
  id        BigInt   @id @default(autoincrement())
  siteId    Int?
  site      Site?    @relation(fields: [siteId], references: [id], onDelete: SetNull)
  articleId Int?
  article   Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)
  path      String   @default("")
  referrer  String   @default("")
  country   String   @default("")
  ua        String   @default("")
  ipHash    String   @default("") // sha256 of IP — for unique counts without storing IPs
  isBot     Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([siteId, createdAt])
  @@index([articleId, createdAt])
}

model Run {
  id          Int       @id @default(autoincrement())
  siteId      Int?
  site        Site?     @relation(fields: [siteId], references: [id], onDelete: SetNull)
  keywordId   Int?
  keyword     Keyword?  @relation(fields: [keywordId], references: [id], onDelete: SetNull)
  articleId   Int?
  article     Article?  @relation(fields: [articleId], references: [id], onDelete: SetNull)
  action      String
  status      String
  message     String    @default("")
  costUsd     Float     @default(0)
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([siteId, startedAt])
}
