generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Neon Postgres for both local dev and Vercel production — same DB.
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

// Auth.js v5 standard models (cuid string IDs)
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  // bcrypt hash; only set when the user signed up via email+password.
  // OAuth-only users (Google) have this null.
  passwordHash  String?
  createdAt     DateTime  @default(now())
  lastLogin     DateTime?

  // Billing — Stripe subscription state.
  // plan: "hobby" | "operator" | "agency". Free users stay on "hobby".
  // articleCredits resets to plan cap on each Stripe renewal webhook.
  plan              String    @default("hobby")
  stripeCustomerId  String?   @unique
  stripeSubId       String?   @unique
  stripePriceId     String?
  planRenewsAt      DateTime?
  articleCredits    Int       @default(10)
  articlesUsed      Int       @default(0)

  // Affiliate program
  // referralCode: this user's own code others can use to sign up under them
  // referredBy:   the referral code that was used when this user signed up
  referralCode      String?   @unique
  referredBy        String?
  payoutEmail       String?   // where commissions go (defaults to user email)

  accounts Account[]
  sessions Session[]
  referrals       Referral[] @relation("Referrer")
  referredAs      Referral[] @relation("Referred")
}

// One row per referred user. Created when someone signs up with a referral
// code in their cookie. Used to compute commissions: when the referred user
// makes a paid subscription, we accrue 30% recurring for 12 months.
model Referral {
  id           Int      @id @default(autoincrement())
  referrerId   String
  referrer     User     @relation("Referrer", fields: [referrerId], references: [id], onDelete: Cascade)
  referredId   String   @unique
  referred     User     @relation("Referred", fields: [referredId], references: [id], onDelete: Cascade)
  status       String   @default("signed_up") // signed_up | subscribed | churned
  totalEarnings Float   @default(0)
  createdAt    DateTime @default(now())

  @@index([referrerId])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Cached SerpApi responses — keyed by keyword to avoid burning the free tier.
// Refreshed when older than the TTL configured in lib/serp.ts.
model SerpCache {
  keyword   String   @id
  json      String
  fetchedAt DateTime @default(now())
}

// Backlink outreach prospects — resource pages, niche blogs, etc. that should
// link to one of the site's articles. Each row is a single target. The whole
// pipeline (find → score → draft email → manual send → track) lives off this.
// Inbound backlinks pointing AT this site. Populated from GSC API, Ahrefs/
// Moz/Majestic CSV import, or manual paste. Used for anchor-text diversity
// analysis — Google penalizes profiles where >40% of anchors are exact-match.
model Backlink {
  id           Int      @id @default(autoincrement())
  siteId       Int
  site         Site     @relation(fields: [siteId], references: [id], onDelete: Cascade)
  sourceUrl    String   // the linking page
  sourceDomain String   // host of the linking page (for deduping referring domains)
  targetUrl    String   // the URL on our site being linked to
  anchorText   String   @default("")
  // exact|partial|branded|generic|naked-url|image — classified at import time
  anchorType   String   @default("partial")
  rel          String   @default("") // dofollow|nofollow|ugc|sponsored
  firstSeen    DateTime @default(now())

  @@unique([siteId, sourceUrl, targetUrl])
  @@index([siteId, anchorType])
}

model OutreachProspect {
  id              Int       @id @default(autoincrement())
  siteId          Int
  site            Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  url             String
  domain          String
  pageTitle       String
  snippet         String    @default("")
  searchSeed      String    @default("") // the query that surfaced this prospect
  relevanceScore  Int       @default(50)
  scoreReason     String    @default("")
  status          String    @default("new") // new | drafted | sent | replied | won | dead
  contactEmail    String?
  draftSubject    String    @default("")
  draftBody       String    @default("")
  notes           String    @default("")
  targetArticleId Int?
  targetArticle   Article?  @relation(fields: [targetArticleId], references: [id], onDelete: SetNull)
  sentAt          DateTime?
  repliedAt       DateTime?
  linkedAt        DateTime?
  createdAt       DateTime  @default(now())

  @@unique([siteId, url])
  @@index([siteId, status])
}

model Site {
  id              Int      @id @default(autoincrement())
  slug            String   @unique
  name            String
  // "wordpress" (default) → publish via WP REST API.
  // "native" → publish to this app's own /blog/[slug] route (dogfood).
  targetType      String   @default("wordpress")
  wpUrl           String   @default("")
  wpUsername      String   @default("")
  // Encrypted with ENCRYPTION_KEY. Never stored in plaintext.
  wpAppPasswordEnc String  @default("")
  niche           String   @default("")
  audience        String   @default("")
  expertVoice     String   @default("")
  authorBioHtml   String   @default("")
  ctaHtml         String   @default("")
  maxPerDay       Int      @default(2)
  minWordCount    Int      @default(1000)
  publishStatus   String   @default("draft")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  // Per-site article theme. Hex colors injected as CSS variables into every
  // generated article so headings, callouts, and tables match the site brand.
  // Customer-facing custom domain (e.g. "blog.theirsite.com") attached to our
  // Vercel project. Status flow: none → pending (added to Vercel, awaiting DNS)
  //   → verifying (DNS resolves, SSL provisioning) → live (serving) | error.
  customDomain       String?  @unique
  customDomainStatus String   @default("none") // none|pending|verifying|live|error
  customDomainError  String?
  customDomainAddedAt DateTime?
  themeAccent     String   @default("#0ea5e9") // primary — H2 border, links, step circles
  themeAccent2    String   @default("#f59e0b") // warm — TL;DR, callouts, key stats
  themeAccent3    String   @default("#22c55e") // success — takeaway callouts, stat boxes
  themeAccent4    String   @default("#a855f7") // accent variety — quote marks, 4th stat box
  // Google Search Console integration. Refresh token is encrypted with
  // ENCRYPTION_KEY (same scheme as wpAppPasswordEnc). gscSiteUrl is the exact
  // property URL registered in Search Console (e.g. "sc-domain:example.com"
  // or "https://example.com/").
  gscRefreshTokenEnc String?
  gscSiteUrl         String?
  gscConnectedAt     DateTime?

  keywords Keyword[]
  articles Article[]
  runs     Run[]
  outreachProspects OutreachProspect[]
  pageViews         PageView[]
  backlinks         Backlink[]
}

model Keyword {
  id          Int       @id @default(autoincrement())
  siteId      Int
  site        Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  keyword     String
  intent      String    @default("informational")
  status      String    @default("queued")
  createdAt   DateTime  @default(now())
  processedAt DateTime?

  articles Article[]
  runs     Run[]

  @@unique([siteId, keyword])
  @@index([siteId, status])
}

model Article {
  id              Int       @id @default(autoincrement())
  siteId          Int
  site            Site      @relation(fields: [siteId], references: [id], onDelete: Cascade)
  keywordId       Int
  keyword         Keyword   @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  title           String
  slug            String
  metaDescription String    @default("")
  html            String
  wordCount       Int       @default(0)
  wpPostId        Int?
  wpUrl           String?
  status          String    @default("draft")
  // JSON-encoded arrays
  categoriesJson  String    @default("[]")
  tagsJson        String    @default("[]")
  inputTokens     Int       @default(0)
  outputTokens    Int       @default(0)
  costUsd         Float     @default(0)
  serpJson        String?   // snapshot of SERP analysis used at generation time
  createdAt       DateTime  @default(now())
  publishedAt     DateTime?

  socialPosts SocialPost[]
  runs        Run[]
  outreachProspects OutreachProspect[]
  pageViews   PageView[]

  @@index([siteId, publishedAt])
}

model SocialPost {
  id         Int      @id @default(autoincrement())
  articleId  Int
  article    Article  @relation(fields: [articleId], references: [id], onDelete: Cascade)
  platform   String
  externalId String?
  postedAt   DateTime @default(now())
}

// Self-hosted pageview tracking. Articles published to WordPress include a
// tiny beacon snippet that POSTs to /api/track on every load. Stored raw so we
// can aggregate by article, day, country, or referrer in the Analytics tab.
model PageView {
  id        BigInt   @id @default(autoincrement())
  siteId    Int?
  site      Site?    @relation(fields: [siteId], references: [id], onDelete: SetNull)
  articleId Int?
  article   Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)
  path      String   @default("")
  referrer  String   @default("")
  country   String   @default("")
  ua        String   @default("")
  ipHash    String   @default("") // sha256 of IP — for unique counts without storing IPs
  isBot     Boolean  @default(false)
  // Set when the request carried an authed Auth.js session cookie. Lets
  // /admin/live show actual user emails per live session instead of opaque
  // ipHash fragments. Nullable — anonymous visitors are still tracked.
  userId    String?
  userEmail String?
  createdAt DateTime @default(now())

  @@index([siteId, createdAt])
  @@index([articleId, createdAt])
  @@index([userId, createdAt])
}

model Run {
  id          Int       @id @default(autoincrement())
  siteId      Int?
  site        Site?     @relation(fields: [siteId], references: [id], onDelete: SetNull)
  keywordId   Int?
  keyword     Keyword?  @relation(fields: [keywordId], references: [id], onDelete: SetNull)
  articleId   Int?
  article     Article?  @relation(fields: [articleId], references: [id], onDelete: SetNull)
  action      String
  status      String
  message     String    @default("")
  costUsd     Float     @default(0)
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([siteId, startedAt])
}
